---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ColorSwatch from "../../components/ColorSwatch.astro";
import PromptBuilder from "../../components/PromptBuilder";
import ApplyThemeButton from "../../components/ApplyThemeButton";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const themes = await getCollection("themes");
  return themes.map((theme) => ({
    params: { slug: theme.data.slug },
    props: { theme },
  }));
}

const { theme } = Astro.props;
const { Content } = await render(theme);
const { data } = theme;
---
<BaseLayout title={data.name} description={`${data.name} — ${data.tagline}. Get a ready-to-use AI prompt for this design style.`}>
  {/* Header */}
  <section class="border-b" style="border-color: var(--tx-card-border);">
    <div class="mx-auto max-w-4xl px-6 py-8">
      <a href="/" class="text-sm transition-colors hover:opacity-80" style="color: var(--tx-text-subtle);">&larr; Back to themes</a>
      <div class="mt-4 flex flex-wrap items-center gap-3">
        <h1 class="text-3xl font-bold" style="font-family: var(--tx-font-heading); color: var(--tx-text);">{data.name}</h1>
        <span class="glass rounded-full px-3 py-1 text-sm font-medium capitalize" style="color: var(--tx-text-muted);">
          {data.category}
        </span>
        <span class="glass rounded-full px-3 py-1 text-sm font-medium" style="color: var(--tx-text-muted);">
          {data.year}
        </span>
      </div>
      <p class="mt-2 text-lg" style="color: var(--tx-text-subtle);">{data.tagline}</p>
      {data.styleTokens && (
        <div class="mt-4">
          <ApplyThemeButton
            client:load
            themeName={data.name}
            themeSlug={data.slug}
            tokens={data.styleTokens}
          />
        </div>
      )}
    </div>
  </section>

  <div class="mx-auto max-w-4xl px-6 py-12">
    {/* Preview */}
    <div class="glass overflow-hidden">
      <img
        src={data.preview}
        alt={`${data.name} preview`}
        class="w-full"
      />
    </div>

    {/* Examples Gallery */}
    {data.examples && data.examples.length > 0 && (
      <div class="mt-10">
        <h2 class="text-lg font-semibold" style="font-family: var(--tx-font-heading); color: var(--tx-text);">Examples</h2>
        <div class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-2">
          {data.examples.map((example) => (
            <div class="glass overflow-hidden">
              <img
                src={example.src}
                alt={`${data.name} — ${example.label}`}
                class="w-full"
                loading="lazy"
              />
              <div class="border-t px-3 py-2" style="border-color: var(--tx-card-border);">
                <span class="text-xs font-medium" style="color: var(--tx-text-subtle);">{example.label}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

    {/* Color Palette */}
    <div class="mt-10">
      <h2 class="text-lg font-semibold" style="font-family: var(--tx-font-heading); color: var(--tx-text);">Color Palette</h2>
      <div class="mt-4 flex flex-wrap gap-6">
        <ColorSwatch label="Primary" color={data.colors.primary} />
        <ColorSwatch label="Secondary" color={data.colors.secondary} />
        <ColorSwatch label="Accent" color={data.colors.accent} />
        <ColorSwatch label="Background" color={data.colors.background} />
        <ColorSwatch label="Text" color={data.colors.text} />
      </div>
    </div>

    {/* Typography */}
    <div class="mt-10">
      <h2 class="text-lg font-semibold" style="font-family: var(--tx-font-heading); color: var(--tx-text);">Typography</h2>
      <div class="mt-3 flex gap-8 text-sm" style="color: var(--tx-text-subtle);">
        <div><span class="font-medium" style="color: var(--tx-text-muted);">Heading:</span> {data.typography.heading}</div>
        <div><span class="font-medium" style="color: var(--tx-text-muted);">Body:</span> {data.typography.body}</div>
      </div>
    </div>

    {/* Characteristics */}
    <div class="mt-10">
      <h2 class="text-lg font-semibold" style="font-family: var(--tx-font-heading); color: var(--tx-text);">Key Characteristics</h2>
      <ul class="mt-3 space-y-2">
        {data.characteristics.map((c) => (
          <li class="flex items-start gap-2 text-sm" style="color: var(--tx-text-muted);">
            <span class="mt-1 h-1.5 w-1.5 shrink-0 rounded-full" style="background: var(--tx-text-subtle);" />
            {c}
          </li>
        ))}
      </ul>
    </div>

    {/* Tags */}
    <div class="mt-10">
      <h2 class="text-lg font-semibold" style="font-family: var(--tx-font-heading); color: var(--tx-text);">Tags</h2>
      <div class="mt-3 flex flex-wrap gap-2">
        {data.tags.map((tag) => (
          <span class="glass rounded-full px-3 py-1 text-xs" style="color: var(--tx-text-subtle);">
            {tag}
          </span>
        ))}
      </div>
    </div>

    {/* MDX Content */}
    <div class="prose prose-glass mt-10 max-w-none">
      <Content />
    </div>

    {/* Prompt Builder */}
    <div class="mt-12">
      <PromptBuilder
        client:load
        themeName={data.name}
        characteristics={data.characteristics}
        colors={data.colors}
        typography={data.typography}
      />
    </div>
  </div>
</BaseLayout>
