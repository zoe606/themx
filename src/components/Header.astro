---
const navLinks = [
  { href: "/", label: "Themes" },
  { href: "/about", label: "About" },
];
---
<header class="glass sticky top-0 z-50 rounded-none border-x-0 border-t-0 border-b border-white/10">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <a href="/" class="text-xl font-bold tracking-tight" style="font-family: var(--tx-font-heading); color: var(--tx-text);">
      themx
    </a>
    <nav class="flex gap-6">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-sm font-medium transition-colors hover:opacity-100"
          style="color: var(--tx-text-muted);"
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>
