---
interface Props {
  label: string;
  color: string;
}

const { label, color } = Astro.props;
---
<div class="flex flex-col items-center gap-1.5">
  <div
    class="h-12 w-12 rounded-lg border"
    style={`background-color: ${color}; border-color: var(--tx-card-border);`}
  />
  <span class="text-xs font-medium" style="color: var(--tx-text-muted);">{label}</span>
  <span class="text-xs" style="color: var(--tx-text-subtle);">{color}</span>
</div>
